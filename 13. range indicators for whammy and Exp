// --- CORE 0: MIDI CONTROL TASK (Priority 2) ---
void MidiTask(void * pvParameters) {
    static bool lastBtState = false; 
    static analog_t lastMidiA = 8192; 
    static analog_t lastMidiB = 8192; 
    
    lastActivityTime = millis(); 
    lastScreenActivityTime = millis(); 

    for(;;) {

        if (pitchShiftLUT[8192] == 0) { vTaskDelay(pdMS_TO_TICKS(100)); continue; }
        
        // This single line now handles sending pedals AND receiving callbacks!
        Control_Surface.loop();

        // 1. Connectivity Check
        bool btConnected = btmidi.isConnected();
        if (btConnected != lastBtState) {
            if (!isScreenOff) forceUIUpdate = true;
            lastBtState = btConnected;
            lastActivityTime = millis(); 
        }

        // 2. Sleep/Timeout Logic
        if (!isScreenOff && (millis() - lastScreenActivityTime > SCREEN_OFF_TIMEOUT)) {
            turnScreenOff();
        }
        if (!btConnected && (millis() - lastActivityTime > LIGHT_SLEEP_TIMEOUT)) {
            goToLightSleep();
            lastScreenActivityTime = millis(); 
        }

        // --- 1. CAROUSEL BUTTON (IO14) LOGIC ---
        bool currentCarouselState = digitalRead(CAROUSEL_BUTTON_PIN);
        if (currentCarouselState == LOW && lastCarouselState == HIGH) {
            carouselPressedTime = millis();
            vTaskDelay(pdMS_TO_TICKS(50)); 
        }
        else if (currentCarouselState == HIGH && lastCarouselState == LOW) {
            unsigned long pressDuration = millis() - carouselPressedTime;
            
            if (pressDuration < 400) {
                // SHORT PRESS: Advance Mode (Works in all modes)
                activeEffectMode++;
                if (activeEffectMode > 4) activeEffectMode = 0;
                
                isHarmonizerMode = false; isCapoMode = false;
                isFeedbackActive = false; feedbackRamp = 0.0f; isFrozen = false; 

                switch(activeEffectMode) {
                    case 1: isFrozen = true; break;
                    case 2: isFeedbackActive = true; break; 
                    case 3: isHarmonizerMode = true; break;
                    case 4: isCapoMode = true; break;
                }
            } else {
                // MEDIUM OR LONG PRESS: Edit Parameters
                if (activeEffectMode == 0) {
                    // WHAMMY MODE: IO14 strictly edits TOE (Memory Slot 0)
                    if (pressDuration < 1500) {
                        effectMemory[0] += 1.0f; // Medium: Increase Upper Interval
                    } else {
                        effectMemory[0] -= 1.0f; // Long: Reduce Upper Interval
                    }
                    if (effectMemory[0] > 24.0f) effectMemory[0] = 24.0f;
                    if (effectMemory[0] < -24.0f) effectMemory[0] = -24.0f;
                } else {
                    // OTHER MODES: Standard Increase (Memory Slot = activeEffectMode)
                    effectMemory[activeEffectMode] += 1.0f;
                    if (effectMemory[activeEffectMode] > 24.0f) effectMemory[activeEffectMode] = 24.0f;
                }
            }
            updateLUT(); forceUIUpdate = true; lastActivityTime = millis();
        }
        lastCarouselState = currentCarouselState;

        // --- 2. BOOT BUTTON (GPIO 0) LOGIC ---
        bool currentBootState = digitalRead(0);
        if (currentBootState == LOW && lastBootState == HIGH) {
            bootPressedTime = millis();
            vTaskDelay(pdMS_TO_TICKS(50));
        } else if (currentBootState == HIGH && lastBootState == LOW) {
            unsigned long pressDuration = millis() - bootPressedTime;
            
            // Ignore Short Presses (< 400ms) entirely. 
            // This safely allows the hardware to wake from sleep without accidentally changing your settings!
            if (pressDuration >= 400) { 
                if (activeEffectMode == 0) {
                    // WHAMMY MODE: Boot strictly edits HEEL (Memory Slot 5)
                    if (pressDuration < 1500) {
                        effectMemory[5] -= 1.0f; // Medium: Decrease Lower Interval
                    } else {
                        effectMemory[5] += 1.0f; // Long: Reduce Lower Interval
                    }
                    if (effectMemory[5] > 24.0f) effectMemory[5] = 24.0f;
                    if (effectMemory[5] < -24.0f) effectMemory[5] = -24.0f;
                } else {
                    // OTHER MODES: Standard Decrease (Memory Slot = activeEffectMode)
                    effectMemory[activeEffectMode] -= 1.0f;
                    if (effectMemory[activeEffectMode] < -24.0f) effectMemory[activeEffectMode] = -24.0f;
                }
                updateLUT(); forceUIUpdate = true;
            }
            lastActivityTime = millis();
        }
        lastBootState = currentBootState;

        // Freeze Button
        bool currentButtonState = digitalRead(FREEZE_BUTTON_PIN);
        if (currentButtonState == LOW && lastButtonState == HIGH) {
            isFrozen = !isFrozen; forceUIUpdate = true; lastActivityTime = millis();
            vTaskDelay(pdMS_TO_TICKS(50)); 
        }
        lastButtonState = currentButtonState;
    
        // --- UNIFIED BUTTON HEARTBEAT (Fix for the Reverse Bug) ---
        // Keeps both timers alive and wakes screen if ANY button is pressed
        if (currentCarouselState == LOW || currentBootState == LOW || currentButtonState == LOW) {
            lastActivityTime = millis();
            lastScreenActivityTime = millis(); // <--- Keeps screen alive!
            if (isScreenOff) turnScreenOn();   // <--- Wakes screen up!
        }
    
        // 4. DUAL INDEPENDENT EXPRESSION PEDAL LOGIC
        filterPB.update();
        filterPB2.update();

        analog_t raw14_A = map(filterPB.getValue(), 0, 4095, 0, 16383);
        analog_t raw14_B = map(filterPB2.getValue(), 0, 4095, 0, 16383);

        analog_t calibratedA = map_PB_Full(raw14_A);
        analog_t calibratedB = map_PB_Full(raw14_B);

        // Update globals for the screen indicators
        currentPB1 = calibratedA;
        currentPB2 = calibratedB;

        // RESTORED: Actually check if the pedals moved more than 8 units
         bool movedA = false; // abs((int)calibratedA - (int)lastMidiA) > 8;
        bool movedB = false; // abs((int)calibratedB - (int)lastMidiB) > 8; 

        if (movedA || movedB) {
            if (isScreenOff) turnScreenOn(); 
            lastScreenActivityTime = millis(); 

            analog_t activeMidi = movedB ? calibratedB : calibratedA;

            pitchShiftFactor = pitchShiftLUT[constrain(activeMidi, 0, 16383)];
            Control_Surface.sendPitchBend(Channel_1, activeMidi);

            lastMidiA = calibratedA;
            lastMidiB = calibratedB;
            lastMidiSent = activeMidi;
            
            forceUIUpdate = true; // Tell screen to instantly redraw the moving bars!
        }

        vTaskDelay(pdMS_TO_TICKS(5)); // <--- ADD THIS YIELD
    } // <--- ADD THIS BRACE (Closes the for-loop)
} // <--- ADD THIS BRACE (Closes MidiTask)


void init_i2s_modern() {
// ...
    i2s_chan_config_t chan_cfg = I2S_CHANNEL_DEFAULT_CONFIG(I2S_NUM_0, I2S_ROLE_MASTER);
    i2s_new_channel(&chan_cfg, &tx_chan, &rx_chan);

    i2s_std_config_t std_cfg = {
        .clk_cfg = I2S_STD_CLK_DEFAULT_CONFIG(SAMPLING_FREQUENCY),
        .slot_cfg = I2S_STD_MSB_SLOT_DEFAULT_CONFIG(I2S_DATA_BIT_WIDTH_24BIT, I2S_SLOT_MODE_STEREO),
        .gpio_cfg = {
            .mclk = I2S_GPIO_UNUSED,
            .bclk = (gpio_num_t)10, 
            .ws   = (gpio_num_t)12,
            .dout = (gpio_num_t)16,
            .din  = (gpio_num_t)17,
            .invert_flags = { .mclk_inv = false, .bclk_inv = false, .ws_inv = false },
        },
    };

    i2s_channel_init_std_mode(tx_chan, &std_cfg);
    i2s_channel_init_std_mode(rx_chan, &std_cfg);
    i2s_channel_enable(tx_chan);
    i2s_channel_enable(rx_chan);
}

// --- INCOMING MIDI LISTENER ---
// This function catches all incoming MIDI messages from your smartphone
// --- INCOMING MIDI LISTENER ---
// This function catches all incoming MIDI messages from your smartphone
bool channelMessageCallback(ChannelMessage cm) {
    int newMode = -1;

    // 1. Listen for Program Change (PC) on Channel 1 (MIDI Header 0xC0)
    if (cm.header == 0xC0) {
        uint8_t pcValue = cm.data1; // Gets the program number (0-127)
        
        // Map PC 0-4 directly to your 5 effects
        if (pcValue >= 0 && pcValue <= 4) {
            newMode = pcValue; 
            Serial.printf("Received PC: Switching to Effect %d\n", newMode);
        }
    }
    // 2. Listen for Control Change (CC) on Channel 1 (MIDI Header 0xB0)
    else if (cm.header == 0xB0) {
        uint8_t ccNumber = cm.data1; // Which CC knob/button was turned
        uint8_t ccValue = cm.data2;  // The value of that knob/button (0-127)

        // --- A. Effect Mode Carousel (CC #3) ---
        if (ccNumber == 3) {
            if (ccValue == 127) {
                newMode = activeEffectMode + 1;
                if (newMode > 4) newMode = 0; // Loop back to Whammy after Capo
                Serial.printf("Received CC 3: Advancing Carousel to Effect %d\n", newMode);
            }
        }
        
        // --- B. Freeze Activate/Deactivate (CC #110) ---
        else if (ccNumber == 110) {
            if (ccValue == 127) {
                isFrozen = true;
                Serial.println("MIDI: Freeze ON");
            } else if (ccValue == 0) {
                isFrozen = false;
                Serial.println("MIDI: Freeze OFF");
            }
            forceUIUpdate = true;
            if (isScreenOff) turnScreenOn(); 
            lastActivityTime = millis(); 
            lastScreenActivityTime = millis();
        }
        
        // --- C. Feedback Activate/Deactivate (CC #111) ---
        else if (ccNumber == 111) {
            if (ccValue == 127) {
                isFeedbackActive = true;
                Serial.println("MIDI: Feedback ON");
            } else if (ccValue == 0) {
                isFeedbackActive = false;
                Serial.println("MIDI: Feedback OFF");
            }
            forceUIUpdate = true;
            if (isScreenOff) turnScreenOn(); 
            lastActivityTime = millis(); 
            lastScreenActivityTime = millis();
        }

        // --- D. Whammy Expression Sweep (CC #11) ---
        else if (ccNumber == 11) {
            uint16_t mappedMidi = map(ccValue, 0, 127, 0, 16383);
            
            currentCC11 = mappedMidi; // Update the global tracker for the screen!
            
            pitchShiftFactor = pitchShiftLUT[mappedMidi];
            lastMidiSent = mappedMidi;
            
            forceUIUpdate = true; // Tell the screen to instantly redraw the indicators!
            if (isScreenOff) turnScreenOn(); 
            lastActivityTime = millis(); 
            lastScreenActivityTime = millis();
        }
    }

    // 3. Apply the Effect Change (For PC and Carousel Switching)
    if (newMode != -1 && newMode != activeEffectMode) {
        activeEffectMode = newMode;

        // Turn everything OFF to guarantee a clean slate
        isHarmonizerMode = false;
        isCapoMode = false;
        isFeedbackActive = false; 
        feedbackRamp = 0.0f;
        isFrozen = false; 

        // Auto-Activate the new mode
        switch(activeEffectMode) {
            case 0: break; // Whammy
            case 1: isFrozen = true; break;
            case 2: isFeedbackActive = true; break; 
            case 3: isHarmonizerMode = true; break;
            case 4: isCapoMode = true; break;
        }

        // Update the audio engine and the screen
        updateLUT();
        forceUIUpdate = true; 
        
        if (isScreenOff) turnScreenOn(); 
        lastActivityTime = millis(); 
        lastScreenActivityTime = millis();
    }

    return false; 
}

void setup() {
    // 1. Double ensure clamp is applied here as well (redundancy)
    pinMode(38, OUTPUT); digitalWrite(38, LOW); 
    pinMode(15, OUTPUT); digitalWrite(15, HIGH); 

    Serial.begin(SERIAL_BAUDRATE);

    // 2. Initialize the screen quietly in the dark
    tft.init();
    tft.setRotation(1); 
    spr.createSprite(tft.width(), tft.height());

    // 3. Wipe the leftover memory clean and draw the boot text
    tft.fillScreen(TFT_BLACK);
    tft.setTextDatum(MC_DATUM);
    tft.setTextSize(3);
    tft.setTextColor(TFT_WHITE, TFT_BLACK);
    tft.drawString("BOOTING...", tft.width() / 2, tft.height() / 2);

    // 4. ST7789 Requirement: Wait for the chip to settle
    delay(120);

    // 5. NOW turn on the real backlight! (Clean pop-in)
    digitalWrite(38, HIGH);

    btmidi.setName("Whammy_S3");
    pinMode(CAROUSEL_BUTTON_PIN, INPUT_PULLUP);
    pinMode(FREEZE_BUTTON_PIN, INPUT_PULLUP); // Now dedicated pin 2
    pinMode(0, INPUT_PULLUP); // Boot button

    // --- PLACE THE OVERRIDES HERE FOR YOUR TEST ---
    pinMode(pinPB, INPUT_PULLUP);  // Ties A0 to High to stop noise
    pinMode(pinPB2, INPUT_PULLUP); // Ties A2 to High to stop noise
    
    FilteredAnalog<>::setupADC();
  // 1. Send MIDI OUT from the ESP32 to your phone/PC
    Control_Surface >> pipes >> btmidi;
    Control_Surface >> pipes >> usbmidi;

    // 2. Receive MIDI IN from your phone/PC into the ESP32
    btmidi >> pipes >> Control_Surface;
    usbmidi >> pipes >> Control_Surface;

    // 3. Attach the Custom Listener we just built
    Control_Surface.setMIDIInputCallbacks(channelMessageCallback, nullptr, nullptr, nullptr);

    Control_Surface.begin();

    init_i2s_modern();
    calibrateCenterAndDeadzone();
    Control_Surface.sendPitchBend(Channel_1, 8192);
    lastMidiSent = 8192;
    
    initTrigLUT();
    updateLUT();

    xTaskCreatePinnedToCore(DisplayTask, "Display", 8192, NULL, 1, NULL, 0); 
    xTaskCreatePinnedToCore(MidiTask, "Midi", 8192, NULL, 2, NULL, 0);       
    xTaskCreatePinnedToCore(AudioDSPTask, "DSP", 16384, NULL, configMAX_PRIORITIES - 1, &audioTaskHandle, 1);
}

